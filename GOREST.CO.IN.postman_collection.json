                {
                  "name": "create user with valid data",
                  "event": [
                    {
                      "listen": "test",
                      "script": {
                        "exec": [
                          "",
                          "// Parse response body",
                          "const jsonData = pm.response.json();",
                          "",
                          "// 1. Assert status code is 201",
                          "pm.test(\"Status code is 201\", function () {",
                          "    pm.response.to.have.status(201);",
                          "});",
                          "",
                          "// 2. Assert `id` exists and is a number",
                          "pm.test(\"id exists and is a number\", function () {",
                          "    pm.expect(jsonData).to.have.property(\"id\");",
                          "    pm.expect(jsonData.id).to.be.a(\"number\");",
                          "});",
                          "",
                          "// 3. Assert `name` exists, is a string, and equals env variable",
                          "pm.test(\"name exists, is a string, and matches environment variable\", function () {",
                          "    pm.expect(jsonData).to.have.property(\"name\");",
                          "    pm.expect(jsonData.name).to.be.a(\"string\");",
                          "    pm.expect(jsonData.name).to.eql(pm.iterationData.get(\"name\"));",
                          "});",
                          "",
                          "// 4. Assert `email` exists, is a string, and equals env variable",
                          "pm.test(\"email exists, is a string, and matches environment variable\", function () {",
                          "    pm.expect(jsonData).to.have.property(\"email\");",
                          "    pm.expect(jsonData.email).to.be.a(\"string\");",
                          "    pm.expect(jsonData.email).to.eql(pm.iterationData.get(\"email\"));",
                          "});",
                          "",
                          "// 5. Assert `gender` exists, is a string, and equals env variable",
                          "pm.test(\"gender exists, is a string, and matches environment variable\", function () {",
                          "    pm.expect(jsonData).to.have.property(\"gender\");",
                          "    pm.expect(jsonData.gender).to.be.a(\"string\");",
                          "    pm.expect(jsonData.gender).to.eql(pm.iterationData.get(\"gender\"));",
                          "});",
                          "",
                          "// 6. Assert `status` exists, is a string, and equals env variable",
                          "pm.test(\"status exists, is a string, and matches environment variable\", function () {",
                          "    pm.expect(jsonData).to.have.property(\"status\");",
                          "    pm.expect(jsonData.status).to.be.a(\"string\");",
                          "    pm.expect(jsonData.status).to.eql(pm.iterationData.get(\"status\"));",
                          "});",
                          "",
                          "// Save returned id to environment variable",
                          "pm.environment.set(\"user_id\", jsonData.id);",
                          ""
                        ],
                        "type": "text/javascript",
                        "packages": {},
                        "requests": {}
                      }
                    }
